{
  "name": "geometry-editor",
  "version": "1.0.0",
  "author": "Anish bala sachin",
  "description": "React geometry editor component with ruler, protractor, compass, and protractor tools. Draw lines, angles, arcs, and circles. Export SVG/PNG/JSON. Step-by-step playback for education.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "dependencies": {
    "zustand": "^4.5.0"
  },
  "keywords": [
    "geometry",
    "editor",
    "ruler",
    "protractor",
    "compass",
    "svg",
    "react-component",
    "math",
    "geometry-construction",
    "interactive-geometry",
    "educational-software",
    "geometric-drawing",
    "teaching-tool",
    "euclidean-geometry",
    "canvas",
    "drawing-tool",
    "typescript"
  ],
  "license": "MIT"
}